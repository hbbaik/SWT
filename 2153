word = input()
total = 0

for ch in word:
    if 'a' <= ch <= 'z':
        total += ord(ch) - ord('a') + 1
    else:
        total += ord(ch) - ord('A') + 27

is_prime = True

if total > 1:
    for i in range(2, int(total ** 0.5) + 1):
        if total % i == 0:
            is_prime = False
            break

if is_prime:
    print("It is a prime word.")
else:
    print("It is not a prime word.")
