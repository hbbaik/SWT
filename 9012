T = int(input())

for _ in range(T):
    s = input().strip()
    count = 0
    is_vps = True

    for ch in s:
        if ch == '(':
            count += 1
        else:
            count -= 1

        if count < 0:
            is_vps = False
            break

    if count == 0 and is_vps:
        print("YES")
    else:
        print("NO")
